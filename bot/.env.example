# Discord bot token (Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# The Discord server (guild) this bot manages. Slash commands register instantly there.
GUILD_ID=

# Same database as the server component
MONGODB_URI=mongodb://localhost:27017
DB_NAME=biomebeacon

# Public URL of the server component; included in the key DM so hunters can
# paste it into the macro's "Server URL" field.
PUBLIC_SERVER_URL=https://your-server.example.com
