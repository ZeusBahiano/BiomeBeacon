# MongoDB connection string (Atlas M0 free tier works fine)
MONGODB_URI=mongodb://localhost:27017
DB_NAME=biomebeacon

# Bind address
HOST=0.0.0.0
PORT=8400

# Shown in the macro UI and used as webhook username
SERVER_NAME=My Biome Hunt Community

# Optional: accepted as an admin token even with an empty admin_tokens collection.
# Use it for first login on the dashboard, then create real tokens via the bot.
ADMIN_BOOTSTRAP_TOKEN=

LOG_LEVEL=INFO
